---
const year = new Date().getFullYear();
---

<footer class="bg-black text-white/70 py-16">
  <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-3 gap-10 text-sm">
    <div>
      <p class="font-display text-white text-lg">Chris Jason McQueen</p>
      <p class="mt-2 text-white/50">Faith, photography & film.</p>
    </div>
    <div>
      <p class="text-white/50 uppercase tracking-widest text-xs mb-3">Explore</p>
      <ul class="space-y-2">
        <li><a class="hover:text-white" href="/about">About</a></li>
        <li><a class="hover:text-white" href="/watch">Watch</a></li>
        <li><a class="hover:text-white" href="/weddings">Weddings</a></li>
        <li><a class="hover:text-white" href="/shop">Shop</a></li>
        <li><a class="hover:text-white" href="/blog">Journal</a></li>
        <li><a class="hover:text-white" href="/contact">Contact</a></li>
      </ul>
    </div>
    <div>
      <p class="text-white/50 uppercase tracking-widest text-xs mb-3">Find me</p>
      <ul class="space-y-2">
        <li><a class="hover:text-white" href="https://youtube.com/@chrisjasonmcqueen" target="_blank" rel="noopener">YouTube</a></li>
        <li><a class="hover:text-white" href="mailto:chrisjasonmcqueen@icloud.com">Email</a></li>
      </ul>
    </div>
  </div>
  <div class="max-w-6xl mx-auto px-6 mt-12 pt-6 border-t border-white/10 text-xs text-white/40 flex flex-wrap justify-between gap-2">
    <span>© {year} Chris Jason McQueen. All rights reserved.</span>
    <span>Built with Astro · Hosted on Cloudflare Pages</span>
  </div>
</footer>
