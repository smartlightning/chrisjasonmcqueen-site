---
import { visibleProducts } from '../data/products';
---

<section id="shop" class="bg-black text-white py-32 md:py-48 overflow-hidden">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-20">
      <p class="text-xs uppercase tracking-[0.25em] text-white/60 mb-6 reveal">The Shop</p>
      <h2 class="h-display text-5xl md:text-7xl reveal">
        Tools to help you<br/>
        <span class="text-white/60">walk the walk.</span>
      </h2>
    </div>

    <div class={`grid gap-6 ${visibleProducts.length === 1 ? 'md:grid-cols-1 max-w-2xl mx-auto' : visibleProducts.length === 2 ? 'md:grid-cols-2' : 'md:grid-cols-3'}`}>
      {visibleProducts.map((p, i) => (
        <a
          href={`/shop/${p.slug}`}
          class="group relative rounded-3xl bg-white text-ink p-8 flex flex-col reveal will-parallax overflow-hidden hover:-translate-y-1 transition-transform"
          data-parallax={(0.04 + i * 0.03).toFixed(2)}
        >
          <div class={`absolute -top-24 -right-24 w-64 h-64 rounded-full bg-gradient-to-br ${p.accent} opacity-70 blur-2xl group-hover:opacity-90 transition`}></div>

          <div class="relative">
            <span class="inline-block text-[11px] uppercase tracking-[0.18em] text-muted">{p.badge}</span>
            <h3 class="mt-4 font-display font-semibold text-2xl tracking-tight">{p.title}</h3>
            <p class="mt-3 text-ink/70 leading-relaxed">{p.tagline}</p>
          </div>

          <div class="relative mt-8 pt-6 border-t border-ink/10 flex items-center justify-between">
            <div class="flex items-baseline gap-2">
              <span class="font-display font-semibold text-xl">{p.price}</span>
              {p.originalPrice && (
                <span class="text-sm text-muted line-through">{p.originalPrice}</span>
              )}
            </div>
            <span class="inline-flex items-center gap-1 px-4 py-2 rounded-full bg-ink text-white text-sm font-medium group-hover:bg-ink/85 transition">
              Learn more <span aria-hidden="true">›</span>
            </span>
          </div>
        </a>
      ))}
    </div>

    <p class="mt-10 text-center text-sm reveal">
      <a href="/shop" class="text-white/70 hover:text-white underline underline-offset-4">
        See the full shop →
      </a>
    </p>
  </div>
</section>
