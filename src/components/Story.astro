---
// Pinned Apple-style story section. Add /public/images/story.jpg to replace the blank.
---

<section id="story" class="pin-section bg-paper">
  <div class="pin-inner">
    <!-- Background with subtle parallax -->
    <div
      class="absolute inset-0 will-parallax bg-cover bg-center"
      style="background-image: url('/images/story.jpg');"
      data-parallax="0.12"
      data-parallax-scale="1.08"
    >
      <!-- Strong paper wash so headings + body copy stay readable on top of the photo -->
      <div class="absolute inset-0" style="background: linear-gradient(180deg, rgba(251,251,253,0.55) 0%, rgba(251,251,253,0.85) 55%, rgba(251,251,253,0.95) 100%);"></div>
    </div>

    <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
      <p class="text-xs uppercase tracking-[0.25em] text-ink/60 mb-6 reveal">A bit about me</p>
      <h2 class="h-display text-ink text-5xl md:text-7xl reveal">
        Faith first.<br/>
        <span class="text-ink/55">Frames second.</span>
      </h2>
      <p class="mt-8 text-lg md:text-2xl text-ink/85 max-w-2xl mx-auto leading-snug reveal">
        I'm a part-time wedding & project photographer, and a full-time storyteller for the Kingdom.
        On YouTube I share honest conversations about following Jesus in a noisy world.
      </p>
    </div>
  </div>
</section>
