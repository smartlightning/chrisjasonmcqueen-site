---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { products } from '../../data/products';

export function getStaticPaths() {
  return products.map((p) => ({ params: { slug: p.slug }, props: { product: p } }));
}

const { product } = Astro.props;
const related = products.filter((p) => p.slug !== product.slug);
---

<Base
  title={`${product.title} — Chris Jason McQueen`}
  description={product.tagline}
>
  <Nav />

  <main class="bg-paper pt-24">
    <article class="max-w-6xl mx-auto px-6 py-20">
      <a href="/shop" class="text-sm text-muted hover:text-ink reveal">‹ Back to shop</a>

      <div class="grid md:grid-cols-2 gap-12 lg:gap-20 mt-8">
        <!-- Visual -->
        <div class="reveal">
          <div class={`relative aspect-square rounded-3xl overflow-hidden bg-gradient-to-br ${product.accent}`}>
            <div
              class="absolute inset-0 will-parallax flex items-center justify-center"
              data-parallax="0.06"
            >
              <span class="font-display font-semibold text-white/80 text-3xl tracking-tight drop-shadow-sm text-center px-8">
                {product.title}
              </span>
            </div>
          </div>
        </div>

        <!-- Details -->
        <div class="flex flex-col">
          <span class="text-[11px] uppercase tracking-[0.18em] text-muted reveal">{product.badge}</span>
          <h1 class="h-display text-ink text-4xl md:text-5xl mt-3 reveal">{product.title}</h1>
          <p class="mt-4 text-xl text-ink/70 reveal">{product.tagline}</p>

          <p class="mt-6 text-ink/80 leading-relaxed reveal">{product.description}</p>

          <ul class="mt-8 space-y-2 reveal">
            {product.features.map((f) => (
              <li class="flex items-start gap-3 text-ink/80">
                <span class="mt-2 w-1.5 h-1.5 rounded-full bg-ink/60 shrink-0"></span>
                <span>{f}</span>
              </li>
            ))}
          </ul>

          <div class="mt-10 flex items-center gap-6 reveal">
            <span class="font-display font-semibold text-3xl text-ink">{product.price}</span>
            <a
              href={product.buyUrl}
              target="_blank"
              rel="noopener"
              class="px-7 py-3 rounded-full bg-ink text-white text-sm font-medium hover:bg-ink/85 transition"
            >
              {product.cta}
            </a>
          </div>
          <p class="mt-3 text-xs text-muted reveal">Secure checkout · Instant delivery</p>
        </div>
      </div>

      <!-- FAQ -->
      {product.faq && product.faq.length > 0 && (
        <section class="mt-32 max-w-2xl mx-auto">
          <h2 class="h-display text-ink text-3xl md:text-4xl text-center reveal">Questions?</h2>
          <div class="mt-10 divide-y divide-ink/10 border-y border-ink/10">
            {product.faq.map((item) => (
              <details class="group py-5 reveal">
                <summary class="flex cursor-pointer items-center justify-between text-left text-ink font-medium">
                  <span>{item.q}</span>
                  <span class="text-muted group-open:rotate-45 transition-transform text-2xl leading-none">+</span>
                </summary>
                <p class="mt-3 text-ink/70 leading-relaxed">{item.a}</p>
              </details>
            ))}
          </div>
        </section>
      )}

      <!-- Related -->
      <section class="mt-32">
        <h2 class="h-display text-ink text-3xl md:text-4xl text-center reveal">Also in the shop</h2>
        <div class="mt-10 grid md:grid-cols-2 gap-6">
          {related.map((p) => (
            <a
              href={`/shop/${p.slug}`}
              class="group relative rounded-2xl bg-white text-ink p-6 flex items-center gap-5 reveal overflow-hidden hover:-translate-y-0.5 transition-transform shadow-sm"
            >
              <div class={`relative w-20 h-20 rounded-xl overflow-hidden bg-gradient-to-br ${p.accent} shrink-0`}></div>
              <div class="flex-1">
                <p class="text-[11px] uppercase tracking-[0.18em] text-muted">{p.badge}</p>
                <h3 class="font-display font-semibold text-lg mt-1">{p.title}</h3>
                <p class="text-sm text-ink/60 mt-1">{p.price}</p>
              </div>
              <span class="text-muted group-hover:text-ink transition" aria-hidden="true">›</span>
            </a>
          ))}
        </div>
      </section>
    </article>
  </main>

  <Footer />
</Base>
